graph TD
    classDef agent fill:#e1f5fe,stroke:#01579b,stroke-width:2px;
    classDef toolbox fill:#fff3e0,stroke:#e65100,stroke-width:1px,stroke-dasharray: 3 3;
    classDef db fill:#efebe9,stroke:#3e2723,stroke-width:2px;

    User[Customer Request Prompt] --> Orchestrator

    subgraph Manager_Layer ["Orchestration Layer"]
        Orchestrator["Business Orchestrator Agent"]:::agent
        Orchestrator_Tools["<b>Tool Box:</b><br/>- check_company_cash<br/>- view_financial_health_report"]:::toolbox
        Orchestrator --> Orchestrator_Tools
    end

    Orchestrator -->|1. Check Stock| InventoryAgent
    Orchestrator -->|2. Request Quote| QuoteAgent
    Orchestrator -->|3. Route Checkout| OrderingAgent

    subgraph Inventory_Layer ["Warehouse Dept"]
        InventoryAgent["Inventory Agent"]:::agent
        Inventory_Tools["<b>Tool Box:</b><br/>- check_stock ➔ get_stock_level<br/>- view_catalog_snapshot ➔ get_all_inventory"]:::toolbox
        InventoryAgent --> Inventory_Tools
    end

    subgraph Quote_Layer ["Finance Dept"]
        QuoteAgent["Quote Agent"]:::agent
        Quote_Tools["<b>Tool Box:</b><br/>- query_pricing_history ➔ search_quote_history"]:::toolbox
        QuoteAgent --> Quote_Tools
    end

    subgraph Ordering_Layer ["Fulfillment Dept"]
        OrderingAgent["Ordering Agent"]:::agent
        Ordering_Tools["<b>Tool Box:</b><br/>- record_transaction ➔ create_transaction<br/>- calculate_delivery_timeline ➔ get_supplier_delivery_date"]:::toolbox
        OrderingAgent --> Ordering_Tools
    end

    Inventory_Tools --> DB[(SQLite Database)]:::db
    Quote_Tools --> DB
    Ordering_Tools --> DB
    Orchestrator_Tools --> DB
